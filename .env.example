# ============================================================
# Variables de entorno para los servicios de vigilancia (SEC-7)
#
# Los scripts ya NO llevan secretos hardcodeados: los leen de aqui.
# Despliegue:
#   1) Copiar a un fichero FUERA del repo, p.ej. /etc/vigilancia/vigilancia.env
#   2) Rellenar con los valores REALES (ver CREDENCIALES_REALES.md, gitignored)
#   3) chmod 600 /etc/vigilancia/vigilancia.env
#   4) En cada unit de systemd:  [Service]  EnvironmentFile=/etc/vigilancia/vigilancia.env
#      (nightly_backup como cron: usar  env $(cat /etc/vigilancia/vigilancia.env | xargs) ...
#       o un wrapper que haga 'set -a; . /etc/vigilancia/vigilancia.env; set +a')
#
# NO commitear el fichero real. .env / *.env estan en .gitignore.
# ============================================================

# --- Telegram (bot, watchdog, people_counter, backup) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# IDs autorizados del bot (coma-separados). Si se omite, usa TELEGRAM_CHAT_ID.
AUTHORIZED_IDS=

# --- Frigate API ---
FRIGATE_URL=http://127.0.0.1:5000
FRIGATE_USER=admin
FRIGATE_PASS=

# --- Face Recognition (opcional; vacio = desactivado) ---
FACE_API_URL=http://100.64.10.5:5050
FACE_API_KEY=

# --- Grafana (solo para grafana_add_panels.py) ---
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_USER=admin
GRAFANA_PASS=

# --- people_counter ---
DB_PATH=/opt/vigilancia/people_counter.db
METRICS_PORT=9102
SYNC_INTERVAL=300

# --- MQTT (face_bridge) ---
MQTT_HOST=127.0.0.1
MQTT_PORT=1883

# --- nightly_backup (HDD) ---
# Preferir LABEL/UUID sobre /dev/sdbN (BUG-17).
HDD_LABEL=vigilancia-backup
HDD_UUID=

# --- backup_to_pve (RES-2) — backup diario de DB/config al servidor pve ---
PVE_HOST=100.64.10.6
PVE_USER=root
PVE_DEST_DIR=/var/backups/vigilancia
PVE_RETENTION_DAYS=14
# Rutas dentro del LXC 200 (verificadas en vivo):
PC_DB=/opt/vigilancia/people_counter.db
FRIGATE_CONFIG=/opt/vigilancia/config/frigate.yml
FRIGATE_DB=/opt/vigilancia/frigate_config/frigate.db

# --- diag_lugar2_cam — diagnostico remoto por capas de cam5/cam6 del Lugar 2 ---
# Solo el password es secreto; el resto son valores publicos (ya en BIBLIA) y el
# script los trae por defecto, pero se pueden override aqui.
PROXY_LUGAR2_HOST=100.64.10.3
LUGAR2_RTSP_USER=admin
CAM5_LAN_IP=198.51.100.30
CAM6_LAN_IP=198.51.100.40
CAM5_RTSP_PASS=
CAM6_RTSP_PASS=
# Canary para distinguir "camara caida" de "sin subnet-routing a 198.51.100.0/24".
# Por defecto cam5 (.199), historicamente la que responde a IP.
LUGAR2_ROUTING_CANARY=198.51.100.30

# --- alert_notify (RES-8) — canal de alertas de respaldo ---
# ntfy: dejar NTFY_URL vacio para desactivar. Usar un canal con nombre dificil de adivinar.
#   p.ej. https://ntfy.sh/vigi-<algo-aleatorio>   o un ntfy self-host.
NTFY_URL=
NTFY_TOKEN=
