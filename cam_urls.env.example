# ============================================================
# URLs RTSP reales de las camaras (SEC-7) - SOLO para el RPi5 (visor mpv)
#
# Los scripts matrix_camaras_*.sh ya NO llevan las URLs con password.
# Despliegue en el RPi5:
#   1) Copiar a /etc/vigilancia/cam_urls.env
#   2) Rellenar con las URLs REALES (user:pass) - ver CREDENCIALES_REALES.md
#   3) chmod 600 /etc/vigilancia/cam_urls.env
# El script hace 'source /etc/vigilancia/cam_urls.env' si existe; si no, usa
# placeholders inertes (rtsp://USER:PASS@...) y el visor no conectara.
#
# NO commitear el fichero real. cam_urls.env / *.env estan en .gitignore.
# ============================================================

CAM_URLS[1]="rtsp://USER:PASS@192.0.2.40:554/cam/realmonitor?channel=1&subtype=1"
CAM_URLS[2]="rtsp://USER:PASS@192.0.2.40:554/cam/realmonitor?channel=2&subtype=1"
CAM_URLS[3]="rtsp://USER:PASS@192.0.2.40:554/cam/realmonitor?channel=3&subtype=1"
CAM_URLS[4]="rtsp://USER:PASS@192.0.2.40:554/cam/realmonitor?channel=4&subtype=1"
CAM_URLS[5]="rtsp://USER:PASS@198.51.100.30/ch0_1.h264"
CAM_URLS[6]="rtsp://USER:PASS@198.51.100.40/ch0_1.h264"
