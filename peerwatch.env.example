# ============================================================
# peerwatch.env - secretos del dead-man's-switch CAPA 1 (SEC-7)
# SOLO para el host VIGILANTE (capa 1 = RPi5/Lugar 1).
#
# El script peer_watch.sh hace 'source /etc/peerwatch/peerwatch.env' si existe.
# Despliegue:
#   1) Copiar a /etc/peerwatch/peerwatch.env
#   2) Rellenar con los valores REALES - ver CREDENCIALES_REALES.md
#   3) chmod 600 /etc/peerwatch/peerwatch.env  (root:root)
#
# NO commitear el fichero real. *.env esta en .gitignore (solo *.env.example sube).
# Para acotar blast radius en capas 2/3 (Lugar 2 / sitio 3) considerar un
# bot/topic de Telegram separado solo-infra (ver hallazgo PEERWATCH-CAPA1-SECRET-FOOTPRINT).
# ============================================================

# Bot de Telegram para las alertas (puede ser @tu_bot_de_telegram o uno dedicado a infra)
TELEGRAM_TOKEN=123456789:REEMPLAZAR_CON_TOKEN_REAL
TELEGRAM_CHAT_ID=000000000

# Debounce: nº de chequeos fallidos seguidos antes de alertar (timer = 5 min/chequeo)
FAIL_THRESHOLD=3

# Timeout (seg) por chequeo individual (tailscale ping / TCP)
PEER_TIMEOUT=10

# Nombre del vigilante (aparece en cada alerta: "[RPi5-lugar1] ...")
WATCHER_NAME=RPi5-lugar1
